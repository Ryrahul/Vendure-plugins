{
  "name": "@rahul_vendure/vendure-plugin-extra-promotions",
  "version": "1.1.0",
  "description": "Extra promotion conditions and actions for Vendure: first-order, collection-based, stock-level, time-range, weekday, cross-sell and more.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dashboard": {
      "types": "./src/dashboard/index.tsx",
      "import": "./src/dashboard/index.tsx",
      "default": "./src/dashboard/index.tsx"
    }
  },
  "files": [
    "dist/**/*",
    "src/dashboard/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@vendure/core": "^3.0.0"
  },
  "keywords": [
    "vendure",
    "vendure-plugin",
    "promotions",
    "discounts",
    "cross-sell",
    "stock-clearance",
    "collection-discount",
    "happy-hour"
  ],
  "license": "MIT"
}
